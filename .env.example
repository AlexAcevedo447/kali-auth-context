APP_PORT=8080
API_HOST_PORT=18080
ADMINER_HOST_PORT=18081

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=kali_auth_dev
DB_SSLMODE=disable

LOG_LEVEL=debug

RABBITMQ_ENABLED=false
