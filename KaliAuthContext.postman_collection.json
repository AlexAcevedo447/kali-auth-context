          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"TENANT_ID\",\n  \"identification_number\": \"12345678\",\n  \"username\": \"usuario1\",\n  \"email\": \"usuario@correo.com\",\n  \"password\": \"contraseña123A!\"\n}"
